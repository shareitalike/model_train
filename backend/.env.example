APP_NAME=Kaithi OCR System
VERSION=1.0.0
DEBUG=false
API_PREFIX=/api/v1
SECRET_KEY=CHANGE-THIS-TO-256-BIT-RANDOM-KEY-IN-PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DATABASE_URL=postgresql+asyncpg://kaithi:kaithi123@postgres:5432/kaithi_db
DATABASE_SYNC_URL=postgresql://kaithi:kaithi123@postgres:5432/kaithi_db
REDIS_URL=redis://redis:6379/0
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=kaithi-docs
MINIO_SECURE=false
MODEL_PATH=/app/models/kaithi-trocr-finetuned
TROCR_BASE=microsoft/trocr-base-handwritten
MAX_FILE_SIZE_MB=50
OCR_BATCH_SIZE=8
CONFIDENCE_THRESHOLD=0.75
OCR_DPI=300
DEVANAGARI_FONT=/app/fonts/NotoSansDevanagari-Regular.ttf
DEVANAGARI_FONT_BOLD=/app/fonts/NotoSansDevanagari-Bold.ttf
